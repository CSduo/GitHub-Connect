generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  submissions Submission[]
  savedItems  SavedItem[]
  newsletter  NewsletterSubscriber?

  @@map("users")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      AdminRole @default(ADMIN)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  auditLogs AuditLog[]

  @@map("admins")
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  articles Article[]
  papers   Paper[]

  @@map("categories")
}

model Article {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  subtitle       String?
  excerpt        String?
  body           String    @default("")
  categorySlug   String    @map("category_slug")
  category       Category  @relation(fields: [categorySlug], references: [slug])
  tags           String[]  @default([])
  authorName     String?   @map("author_name")
  readingMinutes Int?      @map("reading_minutes")
  heroImageUrl   String?   @map("hero_image_url")
  heroImageAlt   String?   @map("hero_image_alt")
  keyTakeaways   String[]  @default([]) @map("key_takeaways")
  references     Json[]    @default([])
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description")
  audioUrl       String?   @map("audio_url")
  status         ContentStatus @default(DRAFT)
  featured       Boolean   @default(false)
  publishedAt    DateTime? @map("published_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  savedBy SavedItem[]

  @@index([status])
  @@index([categorySlug])
  @@index([publishedAt])
  @@index([featured])
  @@map("articles")
}

model Paper {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  abstract     String?
  body         String    @default("")
  categorySlug String    @map("category_slug")
  category     Category  @relation(fields: [categorySlug], references: [slug])
  tags         String[]  @default([])
  authorName   String?   @map("author_name")
  readingMinutes Int?    @map("reading_minutes")
  pdfUrl       String?   @map("pdf_url")
  coverImageUrl String?  @map("cover_image_url")
  citationText String?   @map("citation_text")
  references   Json[]    @default([])
  peerReviewed Boolean   @default(false) @map("peer_reviewed")
  paperType    PaperType @default(RESEARCH_PAPER) @map("paper_type")
  year         Int?
  doi          String?
  seoTitle     String?   @map("seo_title")
  seoDescription String? @map("seo_description")
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime? @map("published_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  savedBy SavedItem[]

  @@index([status])
  @@index([categorySlug])
  @@index([publishedAt])
  @@index([peerReviewed])
  @@map("papers")
}

model Submission {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])
  submitterName  String @map("submitter_name")
  submitterEmail String @map("submitter_email")
  type        SubmissionType
  title       String
  abstract    String
  notes       String?
  consent     Boolean  @default(false)
  status      SubmissionStatus @default(RECEIVED)
  priority    Priority @default(NORMAL)
  assignedEditorId String? @map("assigned_editor_id")
  editorNotes String?  @map("editor_notes")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  files SubmissionFile[]
  statusHistory SubmissionStatusHistory[]

  @@index([status])
  @@index([userId])
  @@map("submissions")
}

model SubmissionFile {
  id           String   @id @default(cuid())
  submissionId String   @map("submission_id")
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  originalName String   @map("original_name")
  storedName   String   @map("stored_name")
  url          String
  storageKey   String   @map("storage_key")
  mimeType     String   @map("mime_type")
  extension    String
  sizeBytes    Int      @map("size_bytes")
  fileCategory FileCategory @default(MANUSCRIPT) @map("file_category")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([submissionId])
  @@map("submission_files")
}

model SubmissionStatusHistory {
  id          String   @id @default(cuid())
  submissionId String  @map("submission_id")
  submission  Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  status      SubmissionStatus
  notes       String?
  changedBy   String?  @map("changed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([submissionId])
  @@map("submission_status_history")
}

model MediaAsset {
  id          String   @id @default(cuid())
  url         String
  storageKey  String   @map("storage_key")
  mimeType    String   @map("mime_type")
  extension   String
  sizeBytes   Int      @map("size_bytes")
  width       Int?
  height      Int?
  altText     String?  @map("alt_text")
  context     String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("media_assets")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  userId    String?  @unique @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  isActive  Boolean  @default(true) @map("is_active")
  source    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}

model SavedItem {
  id         String     @id @default(cuid())
  userId     String     @map("user_id")
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType   ItemType   @map("item_type")
  itemId     String     @map("item_id")
  createdAt  DateTime   @default(now()) @map("created_at")

  article    Article?   @relation(fields: [itemId], references: [id], map: "saved_item_article")
  paper      Paper?     @relation(fields: [itemId], references: [id], map: "saved_item_paper")

  @@unique([userId, itemType, itemId])
  @@index([userId])
  @@map("saved_items")
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?  @map("admin_id")
  admin      Admin?   @relation(fields: [adminId], references: [id])
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([action])
  @@map("audit_logs")
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

enum Role {
  USER
  ADMIN
}

enum AdminRole {
  ADMIN
  EDITOR
  REVIEWER
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionType {
  ESSAY
  PAPER
  REVIEW
  COMMENTARY
}

enum SubmissionStatus {
  RECEIVED
  UNDER_REVIEW
  REVISION_REQUESTED
  ACCEPTED
  REJECTED
  PUBLISHED
  ARCHIVED
}

enum PaperType {
  RESEARCH_PAPER
  WORKING_PAPER
  REVIEW_ESSAY
  MONOGRAPH
  TRANSLATION
  ARCHIVAL_NOTE
}

enum FileCategory {
  MANUSCRIPT
  COVER
  SUPPORTING
  SUPPLEMENTARY
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ItemType {
  ARTICLE
  PAPER
}
