{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install --filter @workspace/anvikshiki --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/anvikshiki build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
